# Copy to .env (same folder as main.py). No spaces around "=".
# Kaggle → Settings → API: username + Create New Token (key in kaggle.json).

KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=paste_your_api_key_here

# Optional: max rows after merge (default 30000). Use 0 for no limit.
# PIPELINE_MAX_ROWS=30000

# Display currency for charts (ISO 4217): USD, EUR, GBP, CHF, DZD, ...
# PRICE_CURRENCY=USD
